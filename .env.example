# Google Gemini API - Free tier: 60 requests/minute
# Get API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# Optional: OpenRouter for alternative models (free tier available)
# Get API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# NVIDIA API for AI model access
# Get API key at: https://www.nvidia.com/en-us/ai/
NVIDIA_API_KEY=your_nvidia_key_here
# Pinecone Vector Database - Free tier available
# Get API key at: https://app.pinecone.io/
# Your index name from URL: https://rag-chatbot-xyz.pqr.stu-vwb.pinecone.io
# Index name is: rag-chatbot-xyz
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_INDEX=your_index_name
# Optional: required for some Pinecone setups (serverless host)
# PINECONE_HOST=https://rag-chatbot-xyz.pqr.stu-vwb.pinecone.io
# Optional: namespace used for records (default: default)
# PINECONE_NAMESPACE=default
# Optional: integrated embedding field map (record field + query field)
# PINECONE_TEXT_FIELD=text
# PINECONE_QUERY_FIELD=text

# Optional: override model IDs for OpenRouter/NVIDIA aliases in the UI
# OPENROUTER_MODEL_DEEPSEEK_V3=deepseek/deepseek-chat-v3-0324:free
# OPENROUTER_MODEL_DEEPSEEK_R1=deepseek/deepseek-r1-0528:free
# OPENROUTER_MODEL_LLAMA_3_2_3B=meta-llama/llama-3.2-3b-instruct:free
# OPENROUTER_MODEL_MIXTRAL_8X7B=mistralai/mixtral-8x7b-instruct:free
# OPENROUTER_MODEL_QWEN3_235B=qwen/qwen-3-235b-a22b:free
# NVIDIA_MODEL_DEEPSEEK_R1=deepseek/deepseek-r1-0528
# NVIDIA_MODEL_QWEN3=qwen/qwen3-235b-a22b

# AI Provider Selection (gemini, openrouter, nvidia)
# Default: gemini
AI_PROVIDER=gemini

# Optional: disable Pinecone if you don't want to use it
# PINECONE_ENABLED=false
